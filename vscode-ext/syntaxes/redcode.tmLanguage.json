{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Redcode",
  "scopeName": "source.redcode",
  "patterns": [
    {
      "include": "#metadataDirectives"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#labels"
    },
    {
      "include": "#instructionWithModifier"
    },
    {
      "include": "#opcodes"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#predefinedConstants"
    },
    {
      "include": "#addressingModes"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#comma"
    }
  ],
  "repository": {
    "metadataDirectives": {
      "patterns": [
        {
          "name": "comment.line.directive.redcode",
          "match": "^(\\s*);(?i:(name|author|strategy|assert))\\b(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "keyword.control.directive.redcode"
            },
            "2": {
              "name": "string.unquoted.redcode"
            }
          }
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.redcode",
          "match": ";.*$"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.label.redcode",
          "match": "^(\\s*)([A-Za-z_][A-Za-z0-9_]*)(?=\\s+(?:(?i:DAT|MOV|ADD|SUB|MUL|DIV|MOD|JMP|JMZ|JMN|DJN|SEQ|SNE|SLT|SPL|NOP|CMP|ORG|END|EQU|PIN)\\b))",
          "captures": {
            "2": {
              "name": "entity.name.label.redcode"
            }
          }
        }
      ]
    },
    "instructionWithModifier": {
      "patterns": [
        {
          "match": "\\b(?i:(DAT|MOV|ADD|SUB|MUL|DIV|MOD|JMP|JMZ|JMN|DJN|SEQ|SNE|SLT|SPL|NOP|CMP))(\\.(?i:AB|BA|A|B|F|X|I))\\b",
          "captures": {
            "1": {
              "name": "keyword.control.opcode.redcode"
            },
            "2": {
              "name": "keyword.other.modifier.redcode"
            }
          }
        }
      ]
    },
    "opcodes": {
      "patterns": [
        {
          "name": "keyword.control.opcode.redcode",
          "match": "\\b(?i:DAT|MOV|ADD|SUB|MUL|DIV|MOD|JMP|JMZ|JMN|DJN|SEQ|SNE|SLT|SPL|NOP|CMP)\\b"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.control.directive.redcode",
          "match": "\\b(?i:ORG|END|EQU|PIN)\\b"
        }
      ]
    },
    "predefinedConstants": {
      "patterns": [
        {
          "name": "support.constant.redcode",
          "match": "\\b(?i:CORESIZE|MAXPROCESSES|MAXCYCLES|MAXLENGTH|MINDISTANCE|WARRIORS|CURLINE)\\b"
        }
      ]
    },
    "addressingModes": {
      "patterns": [
        {
          "name": "punctuation.definition.addressing.redcode",
          "match": "[#\\$@<>\\{\\}\\*]"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.redcode",
          "match": "(?<![A-Za-z0-9_])-?\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.redcode",
          "match": "[+\\-*/%]"
        }
      ]
    },
    "comma": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.redcode",
          "match": ","
        }
      ]
    }
  }
}
